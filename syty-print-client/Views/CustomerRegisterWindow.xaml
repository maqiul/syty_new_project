<Window x:Class="SytyPrintClient.Views.CustomerRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="接单/登记"
        Width="480" Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <!-- 外层：圆角 + 阴影 -->
    <Border Background="White" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏（可拖拽） ========== -->
            <Border Grid.Row="0" Background="#fafafa" CornerRadius="10,10,0,0" Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="📋 接单/登记" FontSize="16" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                    <!-- 关闭按钮 -->
                    <Button x:Name="BtnClose" Content="✕" Width="28" Height="28" FontSize="13"
                            Foreground="#999" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="Transparent" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#e0e0e0"/>
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ========== 表单区域 ========== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10">
                <StackPanel>

                    <!-- 球员信息 -->
                    <hc:Divider Content="球员信息" HorizontalContentAlignment="Left" Padding="0" Margin="0,0,0,10"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="球员姓名 *" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtPlayerName" hc:InfoElement.Placeholder="请输入球员姓名" FontSize="14" hc:BorderElement.CornerRadius="6"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="联系电话" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtPlayerPhone" hc:InfoElement.Placeholder="请输入联系电话（选填）" FontSize="14" hc:BorderElement.CornerRadius="6"/>
                    </StackPanel>

                    <!-- 器材信息 -->
                    <hc:Divider Content="器材信息" HorizontalContentAlignment="Left" Padding="0" Margin="0,6,0,10"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="球拍型号 *" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtRacketModel" hc:InfoElement.Placeholder="如: YY ASTROX 100ZZ" FontSize="14" hc:BorderElement.CornerRadius="6"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="主线" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtMainString" hc:InfoElement.Placeholder="如: BG65" FontSize="14" hc:BorderElement.CornerRadius="6"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="主线磅数" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtMainTension" hc:InfoElement.Placeholder="如: 28" FontSize="14" hc:BorderElement.CornerRadius="6"
                                    PreviewTextInput="Tension_PreviewTextInput"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="横线" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtCrossString" hc:InfoElement.Placeholder="如: BG80" FontSize="14" hc:BorderElement.CornerRadius="6"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="横线磅数" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <hc:TextBox x:Name="TxtCrossTension" hc:InfoElement.Placeholder="如: 26" FontSize="14" hc:BorderElement.CornerRadius="6"
                                    PreviewTextInput="Tension_PreviewTextInput"/>
                    </StackPanel>

                    <!-- 穿线师选择（V1.1 新增） -->
                    <hc:Divider Content="人员安排" HorizontalContentAlignment="Left" Padding="0" Margin="0,6,0,10"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="穿线师 *" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CbStringer" Height="38" FontSize="14"
                                  hc:BorderElement.CornerRadius="6"
                                  SelectionChanged="CbStringer_SelectionChanged">
                            <ComboBoxItem Content="请选择穿线师" IsEnabled="False" Foreground="#999"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="支付方式" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CbPayStatus" Height="38" FontSize="14"
                                  hc:BorderElement.CornerRadius="6" SelectedIndex="0">
                            <ComboBoxItem Content="已支付"/>
                            <ComboBoxItem Content="签单挂账"/>
                            <ComboBoxItem Content="未支付"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 备注 -->
                    <hc:Divider Content="备注" HorizontalContentAlignment="Left" Padding="0" Margin="0,6,0,10"/>

                    <StackPanel Margin="0,0,0,8">
                        <TextBox x:Name="TxtRemark" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" Padding="10" FontSize="14"
                                 hc:BorderElement.CornerRadius="6" BorderBrush="#ddd" BorderThickness="1"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ========== 底部按钮 ========== -->
            <Border Grid.Row="2" Background="#fafafa" CornerRadius="0,0,10,10" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取 消" Width="80" Height="36" FontSize="14"
                            Background="#f0f0f0" BorderBrush="#d9d9d9" Foreground="#666"
                            Margin="0,0,10,0" Cursor="Hand" Click="BtnCancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e0e0e0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="BtnSubmit" Content="确 认 登 记" Width="110" Height="36" FontSize="14" FontWeight="SemiBold"
                            Background="#1890ff" BorderThickness="0" Foreground="White"
                            Cursor="Hand" Click="BtnSubmit_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#40a9ff"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#bae7ff"/>
                                        <Setter Property="Foreground" Value="#fff"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
