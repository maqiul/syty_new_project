<Window x:Class="SytyPrintClient.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="连接配置"
        Width="420"
        Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <!-- 外层：圆角 + 阴影 -->
    <Border Background="White" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏（可拖拽） ========== -->
            <Border Grid.Row="0" Background="#fafafa" CornerRadius="8,8,0,0" Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="⚙️ 连接配置" FontSize="16" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                    <!-- 关闭按钮 -->
                    <Button x:Name="BtnClose" Content="✕" Width="28" Height="28" FontSize="13"
                            Foreground="#999" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="Transparent" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#e0e0e0"/>
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ========== 表单区域 ========== -->
            <StackPanel Grid.Row="1" Margin="24,16,24,8">
                <!-- 后端地址 -->
                <TextBlock Text="后端地址" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtBackendUrl" hc:InfoElement.Placeholder="http://localhost:8080"
                         FontSize="13" Padding="8,6" Margin="0,0,0,14"/>

                <!-- 租户编码 -->
                <TextBlock Text="租户编码" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtTenantCode" hc:InfoElement.Placeholder="syty"
                         FontSize="13" Padding="8,6" Margin="0,0,0,14"/>

                <!-- 用户名 -->
                <TextBlock Text="用户名" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername" hc:InfoElement.Placeholder="请输入用户名"
                         FontSize="13" Padding="8,6" Margin="0,0,0,14"/>

                <!-- 密码 -->
                <TextBlock Text="密码" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword" hc:InfoElement.Placeholder="请输入密码"
                             FontSize="13" Padding="8,6" Margin="0,0,0,14"/>

                <!-- 🖨️ 打印机列表 -->
                <TextBlock Text="🖨️ 本地打印机 (勾选以注册)" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <ListBox x:Name="LstPrinters" Height="120" BorderBrush="#d0d0d0" BorderThickness="1"
                         SelectionMode="Multiple" Margin="0,0,0,6"
                         ItemsSource="{Binding PrinterOptions}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="ℹ️ 保存配置时将自动注册勾选的打印机到后台" FontSize="10" Foreground="#888" Margin="0,0,0,14"/>
            </StackPanel>

            <!-- ========== 底部选项 + 按钮 ========== -->
            <Border Grid.Row="2" Background="#fafafa" CornerRadius="0,0,8,8" Padding="20,12">
                <StackPanel>
                    <!-- 自动连接选项 -->
                    <CheckBox x:Name="CbAutoStart" Content="🚀 启动软件后自动连接" Margin="0,0,0,10" FontSize="13" Foreground="#444"/>

                    <!-- 底部按钮行 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel" Content="取消" Width="90" Height="34" FontSize="13"
                                Background="White" Foreground="#666" BorderBrush="#d0d0d0" BorderThickness="1"
                                Cursor="Hand" Click="BtnCancel_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#f0f0f0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="BtnSave" Content="💾 保存配置" Width="130" Height="34" FontSize="13" FontWeight="SemiBold"
                                Background="#0078d4" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Margin="12,0,0,0" Click="BtnSave_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#006cbe"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#b0c4de"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
