<Border x:Class="SytyPrintClient.Views.OrderDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        CornerRadius="10" Width="420" Height="420"
        Background="{DynamicResource RegionBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🏸" FontSize="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="新订单待打印" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <hc:Badge Text="NEW" BadgeMargin="8,-4,0,0" VerticalAlignment="Center"
                      Style="{DynamicResource BadgeDanger}" Status="Processing"/>
        </StackPanel>

        <!-- 订单详情卡片 -->
        <hc:Card Grid.Row="1" BorderThickness="0" Effect="{DynamicResource EffectShadow2}" Margin="0,0,0,12">
            <StackPanel Margin="14">
                <hc:Divider Content="订单信息" HorizontalContentAlignment="Left" Padding="0" Margin="0,0,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="订单号" Foreground="#999" FontSize="13"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtOrderNo" Text="-" FontWeight="Bold" FontSize="13"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="球  馆" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtShopName" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="球  员" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtPlayerName" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="电  话" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtPlayerPhone" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="球  拍" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtRacketModel" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="主  线" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtMainString" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="主线磅数" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtMainTension" Text="-" FontSize="13" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="备  注" Foreground="#999" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TxtRemark" Text="-" FontSize="13" Margin="0,4,0,0"
                               Foreground="#ff6b6b" FontWeight="Bold"/>
                </Grid>
            </StackPanel>
            <hc:Card.Footer>
                <hc:Divider Margin="0"/>
            </hc:Card.Footer>
        </hc:Card>

        <!-- 按钮组 -->
        <hc:ButtonGroup Grid.Row="2" Height="40">
            <Button Content="❌ 忽略" Style="{DynamicResource RadioGroupItemHorizontalFirst}"
                    Command="hc:ControlCommands.Close" FontSize="14"/>
            <Button x:Name="BtnPrint" Content="🖨️ 确认打印" Style="{DynamicResource RadioGroupItemHorizontalLast}"
                    Click="BtnPrint_Click" FontSize="14"/>
        </hc:ButtonGroup>
    </Grid>
</Border>
